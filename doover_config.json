{
    "analog_flow_meter": {
        "name": "analog_flow_meter",
        "display_name": "Analog Flow Meter",
        "type": "DEV",
        "visibility": "PUB",
        "allow_many": true,
        "description": "Read flow from an analog input or by counting digital pulses, with a calibratable totaliser and flow-event tracking.",
        "long_description": "README.md",
        "depends_on": [],
        "owner_org_key": "",
        "container_registry_profile_id": 93955828574386692,
        "image_name": "ghcr.io/getdoover/analog-flow-meter:main",
        "build_args": "--platform linux/amd64,linux/arm64",
        "config_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "",
            "title": "$default",
            "type": "object",
            "properties": {
                "meter_mode": {
                    "enum": [
                        "Analog",
                        "Pulse"
                    ],
                    "title": "Meter Mode",
                    "x-name": "meter_mode",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "How flow is measured: an analog input (e.g. 4-20mA / 0-10V) or by counting digital pulses.",
                    "default": "Analog",
                    "x-position": 0
                },
                "flow_units": {
                    "title": "Flow Units",
                    "x-name": "flow_units",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Volume units for flow and totaliser (e.g. L, kL, gal, m3).",
                    "default": "L",
                    "x-position": 1
                },
                "flow_rate_time_base": {
                    "enum": [
                        "Per Second",
                        "Per Minute",
                        "Per Hour",
                        "Per Day"
                    ],
                    "title": "Flow Rate Time Base",
                    "x-name": "flow_rate_time_base",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Time base for the displayed flow rate (e.g. Per Hour shows L/hr, Per Day shows ML/day for megalitre units).",
                    "default": "Per Hour",
                    "x-position": 2
                },
                "maximum_flow": {
                    "title": "Maximum Flow",
                    "x-name": "maximum_flow",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Full-scale flow used to calibrate the radial gauge range, in flow units per the selected time base.",
                    "default": 1000.0,
                    "x-position": 3,
                    "minimum": 0
                },
                "flow_decimal_precision": {
                    "title": "Flow Decimal Precision",
                    "x-name": "flow_decimal_precision",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Number of decimal places shown for the flow rate.",
                    "default": 1,
                    "x-position": 4,
                    "minimum": 0
                },
                "polling_frequency": {
                    "title": "Polling Frequency",
                    "x-name": "polling_frequency",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "How often to sample the meter and update the totaliser (Hz).",
                    "default": 1.0,
                    "x-position": 5,
                    "minimum": 0
                },
                "analog_input_pin": {
                    "title": "Analog Input Pin",
                    "x-name": "analog_input_pin",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Analog mode] Analog input pin the flow transmitter is wired to.",
                    "default": 0,
                    "x-position": 6,
                    "minimum": 0
                },
                "signal_at_minimum_flow": {
                    "title": "Signal at Minimum Flow",
                    "x-name": "signal_at_minimum_flow",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Analog mode] Raw signal (mA or V) corresponding to the minimum flow.",
                    "default": 4.0,
                    "x-position": 7
                },
                "signal_at_maximum_flow": {
                    "title": "Signal at Maximum Flow",
                    "x-name": "signal_at_maximum_flow",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Analog mode] Raw signal (mA or V) corresponding to the maximum flow.",
                    "default": 20.0,
                    "x-position": 8
                },
                "flow_at_minimum_signal": {
                    "title": "Flow at Minimum Signal",
                    "x-name": "flow_at_minimum_signal",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Analog mode] Flow rate (units per time base) at the minimum signal.",
                    "default": 0.0,
                    "x-position": 9
                },
                "flow_at_maximum_signal": {
                    "title": "Flow at Maximum Signal",
                    "x-name": "flow_at_maximum_signal",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Analog mode] Flow rate (units per time base) at the maximum signal.",
                    "default": 1000.0,
                    "x-position": 10
                },
                "signal_deadband": {
                    "title": "Signal Deadband",
                    "x-name": "signal_deadband",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Analog mode] Signal below (signal_min - deadband) is treated as a fault/disconnected and ignored rather than read as flow.",
                    "default": 0.5,
                    "x-position": 11,
                    "minimum": 0
                },
                "sensor_power_pin": {
                    "title": "Sensor Power Pin",
                    "x-name": "sensor_power_pin",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Analog mode] Optional digital output pin used to power the transmitter.",
                    "default": null,
                    "x-position": 12,
                    "minimum": 0
                },
                "digital_input_pin": {
                    "title": "Digital Input Pin",
                    "x-name": "digital_input_pin",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Pulse mode] Digital input pin the meter's pulse output is wired to. Pins 4 and 5 are voltage-input (VI) pulse counters wired to analog inputs 0 and 1: the firmware polls the voltage and emits a pulse on each step change (see Voltage Pulse Threshold), rather than counting a hardware digital edge.",
                    "default": 0,
                    "x-position": 13,
                    "minimum": 0
                },
                "kfactor_pulses_per_unit": {
                    "title": "K-Factor (pulses per unit)",
                    "x-name": "kfactor_pulses_per_unit",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Pulse mode] Pulses emitted per one unit of volume, from the meter's spec sheet. Volume = pulses / K-factor.",
                    "default": 1.0,
                    "x-position": 14,
                    "minimum": 0
                },
                "pulse_edge": {
                    "enum": [
                        "rising",
                        "falling"
                    ],
                    "title": "Pulse Edge",
                    "x-name": "pulse_edge",
                    "x-hidden": false,
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Pulse mode] Signal edge that constitutes one pulse.",
                    "default": "rising",
                    "x-position": 15
                },
                "voltage_pulse_threshold": {
                    "title": "Voltage Pulse Threshold",
                    "x-name": "voltage_pulse_threshold",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Pulse mode, DI pins 4-5 only] Voltage step (volts) between consecutive ~0.5s samples that registers as one pulse on a VI pulse counter. Rising vs falling step follows the Pulse Edge setting. Set below your pulse output's voltage swing (e.g. ~10 for a 0/24V pulse).",
                    "default": 10.0,
                    "x-position": 16,
                    "minimum": 0
                },
                "pulse_rate_averaging_window": {
                    "title": "Pulse Rate Averaging Window",
                    "x-name": "pulse_rate_averaging_window",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "[Pulse mode] Seconds of pulses to average when computing the displayed flow rate. Larger values smooth a jumpy gauge at low flow; smaller values respond faster. Does not affect the totaliser.",
                    "default": 10.0,
                    "x-position": 17,
                    "minimum": 0
                },
                "totaliser_calibration_factor": {
                    "title": "Totaliser Calibration Factor",
                    "x-name": "totaliser_calibration_factor",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Multiplier applied to the totaliser to trim it against a reference meter (1.0 = no adjustment).",
                    "default": 1.0,
                    "x-position": 18,
                    "minimum": 0
                },
                "totaliser_decimal_precision": {
                    "title": "Totaliser Decimal Precision",
                    "x-name": "totaliser_decimal_precision",
                    "x-hidden": false,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Decimal places shown for the totaliser and event volumes. Increase for small-volume units like m3 or kL.",
                    "default": 0,
                    "x-position": 19,
                    "minimum": 0
                },
                "event_flow_threshold": {
                    "title": "Event Flow Threshold",
                    "x-name": "event_flow_threshold",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Flow rate (units per time base) above which a flow session is considered active. Set this above your sensor's zero/noise floor \u2014 with analog sensors, leaving it at 0 keeps a session open forever on baseline noise (flow rarely reads exactly zero).",
                    "default": 1.0,
                    "x-position": 20,
                    "minimum": 0
                },
                "event_timeout_minutes": {
                    "title": "Event Timeout (minutes)",
                    "x-name": "event_timeout_minutes",
                    "x-hidden": false,
                    "type": [
                        "number",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Minutes of flow at or below the threshold before an active flow session is closed and recorded.",
                    "default": 5.0,
                    "x-position": 21,
                    "minimum": 0
                },
                "simulator_app_key": {
                    "title": "Simulator App Key",
                    "x-name": "simulator_app_key",
                    "x-hidden": false,
                    "format": "doover-resource-application",
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Optional: app key of a simulator publishing a 'sim_flow_rate' tag. When set, flow is read from that tag instead of hardware (local testing).",
                    "default": null,
                    "x-position": 22
                },
                "dv_app_position": {
                    "title": "Position",
                    "x-name": "dv_app_position",
                    "x-hidden": true,
                    "type": [
                        "integer",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Position of Application in UI Structure. Smaller numbers are closer to the top.",
                    "default": 100,
                    "x-position": 23,
                    "minimum": 0
                }
            },
            "additionalElements": true,
            "required": []
        },
        "ui_schema": {
            "displayString": "$config.app().APP_DISPLAY_NAME",
            "hidden": "$config.app().hidden:boolean:false:boolean:false",
            "position": "$config.app().dv_app_position:number:100",
            "icon": null,
            "colour": null,
            "defaultOpen": "$config.app().dv_app_default_open:boolean",
            "type": "uiApplication",
            "name": "$config.app().APP_KEY",
            "children": {
                "tabs": {
                    "name": "tabs",
                    "type": "uiTabs",
                    "displayString": "Tabs",
                    "showActivity": true,
                    "position": 63,
                    "hidden": false,
                    "children": {
                        "flow_tab": {
                            "name": "flow_tab",
                            "type": "uiContainer",
                            "displayString": "Flow",
                            "showActivity": true,
                            "position": 55,
                            "hidden": false,
                            "children": {
                                "sensor_fault": {
                                    "name": "sensor_fault",
                                    "type": "uiWarningIndicator",
                                    "displayString": "Sensor signal out of range",
                                    "position": 5,
                                    "hidden": "$tag.app().sensor_fault_hidden:boolean:true",
                                    "currentValue": "$cmds.app().sensor_fault",
                                    "can_cancel": true
                                },
                                "flow_rate": {
                                    "name": "flow_rate",
                                    "type": "uiVariable",
                                    "displayString": "Flow Rate",
                                    "showActivity": true,
                                    "form": "radialGauge",
                                    "position": 10,
                                    "hidden": false,
                                    "units": "L/hr",
                                    "varType": "float",
                                    "currentValue": "$tag.app().flow_rate:number:0.0",
                                    "decPrecision": 1,
                                    "ranges": [
                                        {
                                            "min": 0,
                                            "max": 200,
                                            "colour": "blue",
                                            "show_on_graph": true,
                                            "label": "Low"
                                        },
                                        {
                                            "min": 200,
                                            "max": 800,
                                            "colour": "green",
                                            "show_on_graph": true,
                                            "label": "Normal"
                                        },
                                        {
                                            "min": 800,
                                            "max": 1000,
                                            "colour": "yellow",
                                            "show_on_graph": true,
                                            "label": "High"
                                        }
                                    ],
                                    "live": true
                                },
                                "totaliser": {
                                    "name": "totaliser",
                                    "type": "uiVariable",
                                    "displayString": "Totaliser",
                                    "showActivity": true,
                                    "position": 20,
                                    "hidden": false,
                                    "units": "L",
                                    "varType": "float",
                                    "currentValue": "$tag.app().totaliser:number:0.0",
                                    "decPrecision": 0,
                                    "live": true
                                },
                                "reset_totaliser": {
                                    "name": "reset_totaliser",
                                    "type": "uiButton",
                                    "displayString": "Reset Totaliser",
                                    "position": 30,
                                    "hidden": false,
                                    "currentValue": "$cmds.app().reset_totaliser"
                                }
                            }
                        },
                        "events_tab": {
                            "name": "events_tab",
                            "type": "uiContainer",
                            "displayString": "Events",
                            "showActivity": true,
                            "position": 62,
                            "hidden": false,
                            "children": {
                                "flow_active": {
                                    "name": "flow_active",
                                    "type": "uiVariable",
                                    "displayString": "Flow Active",
                                    "showActivity": true,
                                    "position": 10,
                                    "hidden": false,
                                    "varType": "bool",
                                    "currentValue": "$tag.app().flow_active:boolean:false"
                                },
                                "event_started": {
                                    "name": "event_started",
                                    "type": "uiTimestamp",
                                    "displayString": "Current Event Started",
                                    "showActivity": true,
                                    "position": 20,
                                    "hidden": false,
                                    "varType": "timestamp",
                                    "currentValue": "$tag.app().event_started:number:null"
                                },
                                "event_volume": {
                                    "name": "event_volume",
                                    "type": "uiVariable",
                                    "displayString": "Current Event Volume",
                                    "showActivity": true,
                                    "position": 30,
                                    "hidden": false,
                                    "units": "L",
                                    "varType": "float",
                                    "currentValue": "$tag.app().event_volume:number:0.0",
                                    "decPrecision": 0
                                },
                                "event_peak_flow": {
                                    "name": "event_peak_flow",
                                    "type": "uiVariable",
                                    "displayString": "Current Event Peak Flow",
                                    "showActivity": true,
                                    "position": 40,
                                    "hidden": false,
                                    "units": "L/hr",
                                    "varType": "float",
                                    "currentValue": "$tag.app().event_peak_flow:number:0.0",
                                    "decPrecision": 1
                                },
                                "last_event_summary": {
                                    "name": "last_event_summary",
                                    "type": "uiVariable",
                                    "displayString": "Last Event",
                                    "showActivity": true,
                                    "position": 50,
                                    "hidden": false,
                                    "varType": "string",
                                    "currentValue": "$tag.app().last_event_summary:string:\"\""
                                },
                                "reset_event": {
                                    "name": "reset_event",
                                    "type": "uiButton",
                                    "displayString": "Reset Current Event",
                                    "position": 60,
                                    "hidden": false,
                                    "currentValue": "$cmds.app().reset_event"
                                }
                            }
                        }
                    }
                }
            }
        },
        "organisation_id": null,
        "id": 188129882880872463,
        "key": null,
        "owner_org_id": null,
        "code_repo_id": null,
        "repo_branch": "main",
        "lambda_config": null,
        "icon_url": null,
        "banner_url": null,
        "staging_config": {},
        "build_widget_command": null,
        "export_config_command": null,
        "export_ui_command": null,
        "run_command": null,
        "lambda_arn": null
    }
}